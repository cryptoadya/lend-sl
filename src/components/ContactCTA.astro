<section class="contact section" id="kontakt" aria-labelledby="contact-title">
  <div class="contact-copy">
    <h2 id="contact-title">Persönlich Kontakt aufnehmen</h2>
    <p>
      Sie möchten wissen, ob unsere Unterstützung zu Ihrer Situation passt? Rufen Sie uns an,
      schreiben Sie uns oder nutzen Sie das Formular. Wir melden uns persönlich bei Ihnen.
    </p>
    <div class="contact-list">
      <a href="tel:+491732126091">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.5 3 3.8 5.3 6.7 6.7l2.2-2.1c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.3.6 1.3 1.3v3.5c0 .7-.6 1.3-1.3 1.3C10.4 21.8 2.2 13.6 2.2 3.3 2.2 2.6 2.8 2 3.5 2H7c.7 0 1.3.6 1.3 1.3 0 1.4.2 2.8.6 4 .1.4 0 .9-.3 1.2l-2 2.3Z" /></svg>
        0173 2126091
      </a>
      <a href="mailto:adelmarkt2015@gmail.com">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.8 6.5h16.4v11H3.8v-11Zm0 0 8.2 6.1 8.2-6.1" /></svg>
        adelmarkt2015@gmail.com
      </a>
      <span>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s6.2-5.5 6.2-11.1A6.2 6.2 0 0 0 5.8 9.9C5.8 15.5 12 21 12 21Z" /><path d="M12 12.2a2.3 2.3 0 1 0 0-4.6 2.3 2.3 0 0 0 0 4.6Z" /></svg>
        Petershagener Chaussee 34, 15345 Eggersdorf
      </span>
    </div>
    <figure class="contact-visual">
      <picture>
        <source srcset="/assets/contact-consultation-home.webp" type="image/webp" />
        <img src="/assets/contact-consultation-home.png" loading="lazy" decoding="async" alt="Alltagsbegleiterin bespricht zuhause Unterlagen mit einem Senior" />
      </picture>
    </figure>
  </div>
  <form class="contact-form" data-contact-form>
    <label class="form-field-full">
      Name
      <input name="name" autocomplete="name" required />
    </label>
    <label>
      Telefonnummer
      <input name="phone" type="tel" autocomplete="tel" aria-describedby="contact-return-error" />
    </label>
    <label>
      E-Mail
      <input name="email" type="email" autocomplete="email" aria-describedby="contact-return-error" />
    </label>
    <p class="form-error" id="contact-return-error" data-contact-error role="alert" hidden>
      Bitte geben Sie eine Telefonnummer oder E-Mail-Adresse an, damit wir Sie erreichen können.
    </p>
    <label class="form-field-full">
      Nachricht
      <textarea name="message" rows="5" required></textarea>
    </label>
    <label class="privacy-check">
      <input name="privacy" type="checkbox" required />
      <span>
        Ich bin damit einverstanden, dass meine Angaben zur Kontaktaufnahme verwendet werden.
        Informationen dazu stehen in der <a href="/datenschutz">Datenschutzerklärung</a>.
      </span>
    </label>
    <button class="btn btn-primary" type="submit">
      Unverbindlich anfragen
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12 20 4l-7 16-2-7-7-1Z" /></svg>
    </button>
    <p class="form-note">Das Formular öffnet Ihr E-Mail-Programm mit der vorbereiteten Nachricht.</p>
  </form>
</section>
