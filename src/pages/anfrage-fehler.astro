---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Anfrage nicht gesendet | S-Line Seniorenhilfe";
const description = "Hinweis zur nicht abgeschlossenen Kontaktanfrage.";
---

<BaseLayout
  title={title}
  description={description}
  path="/anfrage-fehler"
  noindex={true}
>
  <Header />
  <main class="result-page section">
    <section class="result-card" aria-labelledby="result-title">
      <h1 id="result-title">Ihre Anfrage konnte nicht gesendet werden</h1>
      <p>
        Bitte prüfen Sie Ihre Angaben und versuchen Sie es erneut. Ihre zuvor
        eingegebenen Daten wurden nicht in dieser Seite oder der Adresse gespeichert.
      </p>
      <div class="result-actions">
        <a class="btn btn-primary" href="/#kontaktformular">Zurück zum Formular</a>
      </div>
      <p class="result-contact">
        Alternativ erreichen Sie uns telefonisch unter
        <a href="tel:+491732126091">0173 2126091</a> oder per E-Mail an
        <a href="mailto:info@s-line-seniorenhilfe.de">info@s-line-seniorenhilfe.de</a>.
      </p>
    </section>
  </main>
  <Footer />
</BaseLayout>
