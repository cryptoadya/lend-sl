---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Datenschutz | S-Line Seniorenhilfe UG";
const description = "Datenschutzhinweise der S-Line Seniorenhilfe UG.";
---

<BaseLayout title={title} description={description} path="/datenschutz">
  <Header />
  <main class="legal-page section">
    <h1>Datenschutzerklärung</h1>

    <section>
      <h2>Verantwortliche Stelle</h2>
      <p>
        S-Line Seniorenhilfe UG (haftungsbeschränkt)<br />
        Petershagener Chaussee 34<br />
        15345 Petershagen/Eggersdorf<br /><br />

        E-Mail:{" "}
        <a href="mailto:info@s-line-seniorenhilfe.de">
          info@s-line-seniorenhilfe.de
        </a><br />
        Telefon:{" "}
        <a href="tel:+491732126091">+49 173 2126091</a>
      </p>
    </section>

    <section>
      <h2>Hosting</h2>
      <p>
        Diese Website wird über Cloudflare Pages bereitgestellt. Beim Aufruf der
        Website werden technisch erforderliche Daten wie IP-Adresse, Datum und
        Uhrzeit des Zugriffs sowie Browser- und Geräteinformationen verarbeitet,
        um die Website sicher und zuverlässig bereitzustellen.
      </p>
      <p>
        Rechtsgrundlage ist Art. 6 Abs. 1 lit. f DSGVO. Unser berechtigtes
        Interesse liegt im sicheren Betrieb dieser Website.
      </p>
    </section>

    <section>
      <h2>Kontaktformular</h2>
      <p>
        Wenn Sie uns über das Kontaktformular, per E-Mail oder telefonisch
        kontaktieren, verarbeiten wir Ihre Angaben zur Bearbeitung Ihrer Anfrage.
        Dies betrifft insbesondere Name, Telefonnummer, E-Mail-Adresse und den
        Inhalt Ihrer Nachricht.
      </p>
      <p>
        Rechtsgrundlage ist Art. 6 Abs. 1 lit. b DSGVO, soweit Ihre Anfrage auf
        einen Vertrag oder eine vorvertragliche Maßnahme gerichtet ist. Im
        Übrigen erfolgt die Verarbeitung auf Grundlage von Art. 6 Abs. 1 lit. f
        DSGVO.
      </p>
      <p>
        Für den Versand von Anfragen aus dem Kontaktformular nutzen wir Resend
        als technischen Dienstleister. Die Daten werden nur so lange gespeichert,
        wie dies zur Bearbeitung Ihrer Anfrage und zur Erfüllung gesetzlicher
        Aufbewahrungspflichten erforderlich ist.
      </p>
    </section>

    <section>
      <h2>Cookies und Tracking</h2>
      <p>
        Diese Website verwendet keine Analyse- oder Marketing-Cookies, kein
        Tracking und keine eingebetteten Dienste wie Google Maps oder YouTube.
      </p>
    </section>

    <section>
      <h2>Ihre Rechte</h2>
      <p>
        Sie haben das Recht auf Auskunft, Berichtigung, Löschung, Einschränkung
        der Verarbeitung, Datenübertragbarkeit und Widerspruch. Außerdem haben
        Sie das Recht, sich bei einer Datenschutz-Aufsichtsbehörde zu
        beschweren.
      </p>
      <p>
        Für Datenschutzanfragen schreiben Sie bitte an{" "}
        <a href="mailto:info@s-line-seniorenhilfe.de">
          info@s-line-seniorenhilfe.de
        </a>.
      </p>
    </section>

    <section>
      <h2>Stand</h2>
      <p>Stand: Juni 2026</p>
    </section>
  </main>
  <Footer />
</BaseLayout>
