---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Impressum | S-Line Seniorenhilfe UG";
const description = "Impressum der S-Line Seniorenhilfe UG in Eggersdorf.";
---

<BaseLayout title={title} description={description} path="/impressum">
  <Header />
  <main class="legal-page section">
    <h1>Impressum</h1>
    <p class="legal-review-note">Diese Seite erfordert eine finale rechtliche Prüfung.</p>

    <section aria-labelledby="provider-title">
      <h2 id="provider-title">Angaben gemäß § 5 TMG</h2>
      <p>
        S-Line Seniorenhilfe UG<br />
        Petershagener Chaussee 34<br />
        15345 Eggersdorf
      </p>
    </section>

    <section aria-labelledby="contact-title">
      <h2 id="contact-title">Kontakt</h2>
      <p>
        Telefon: <a href="tel:+491732126091">0173 2126091</a><br />
        E-Mail: <a href="mailto:adelmarkt2015@gmail.com">adelmarkt2015@gmail.com</a>
      </p>
    </section>

    <section aria-labelledby="todos-title">
      <h2 id="todos-title">Noch zu ergänzen</h2>
      <ul>
        <li>TODO: Vertretungsberechtigte Person ergänzen.</li>
        <li>TODO: Registergericht und Registernummer ergänzen, falls vorhanden.</li>
        <li>TODO: Umsatzsteuer-ID oder Wirtschafts-ID ergänzen, falls vorhanden.</li>
        <li>TODO: Zuständige Aufsichtsbehörde ergänzen, falls erforderlich.</li>
        <li>TODO: Berufsspezifische Angaben ergänzen, falls erforderlich.</li>
      </ul>
    </section>
  </main>
  <Footer />
</BaseLayout>
