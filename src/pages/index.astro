---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Footer from "../components/Footer.astro";
import JsonLd from "../components/JsonLd.astro";

const title = "S-Line Seniorenhilfe | Anerkannte Alltagshilfe in Märkisch-Oderland";
const description =
  "Anerkannte Unterstützung im Alltag für Menschen mit Pflegegrad in Märkisch-Oderland. Persönliche Begleitung, Entlastung für Angehörige und Abrechnung über den Entlastungsbetrag.";
const site = Astro.site ?? new URL("https://s-line-seniorenhilfe.de");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": new URL("/#localbusiness", site).toString(),
  name: "S-Line Seniorenhilfe UG",
  url: new URL("/", site).toString(),
  telephone: "+491732126091",
  email: "info@s-line-seniorenhilfe.de",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Petershagener Chaussee 34",
    postalCode: "15345",
    addressLocality: "Eggersdorf",
    addressCountry: "DE",
  },
  areaServed: "Märkisch-Oderland",
};
---

<BaseLayout title={title} description={description} path="/">
  <JsonLd slot="head" data={jsonLd} />
  <Header />
  <main id="top">
    <Hero />
    <ServicesGrid />
    <ProcessSteps />
    <ContactCTA />
  </main>
  <Footer />
</BaseLayout>
